{
  "credential_issuer": "${external-url}",
  "credential_endpoint": "${external-url}/oid4vci/api/credential",
  "deferred_credential_endpoint": "${external-url}/oid4vci/api/deferred_credential",
  "nonce_endpoint": "${external-url}/oid4vci/api/nonce",
  "credential_response_encryption": {
    "alg_values_supported": [
      "ECDH-ES"
    ],
    "enc_values_supported": [
      "A128GCM"
    ]
  },
  "version": "1.0",
  "display": [
    {
      "name": "Mein Test Aussteller",
      "locale": "de-CH",
      "logo": {
        "uri": "data:image/png;base64,"
      }
    },
    {
      "name": "My test issuer",
      "locale": "en-US",
      "logo": {
        "uri": "data:image/png;base64,"
      }
    }
  ],
  "batch_credential_issuance": {
    "batch_size": 10
  },
  "credential_configurations_supported": {
    "bound_example_sd_jwt": {
      "format": "vc+sd-jwt",
      "credential_signing_alg_values_supported": [
        "ES256"
      ],
      "cryptographic_binding_methods_supported": [
        "jwk"
      ],
      "proof_types_supported": {
        "jwt": {
          "proof_signing_alg_values_supported": [
            "ES256"
          ]
        }
      },
      "vct": "${external-url}/oid4vci/vct/my-vct-v01",
      "claims": {
        "name": {
          "mandatory": true,
          "value_type": "string",
          "display": [
            { "locale": "en-CH", "name": "Full name" },
            { "locale": "de-CH", "name": "Vollständiger Name" },
            { "locale": "fr-CH", "name": "Nom complet" },
            { "locale": "it-CH", "name": "Nome completo" },
            { "locale": "rm-CH", "name": "Num cumplet" }
          ]
        },

        "job_title": {
          "mandatory": false,
          "value_type": "string",
          "display": [
            { "locale": "en-CH", "name": "Job title" },
            { "locale": "de-CH", "name": "Berufsbezeichnung" },
            { "locale": "fr-CH", "name": "Intitulé du poste" },
            { "locale": "it-CH", "name": "Titolo professionale" },
            { "locale": "rm-CH", "name": "Titgel da professiun" }
          ]
        },

        "annual_salary": {
          "mandatory": true,
          "value_type": "number",
          "display": [
            { "locale": "en-CH", "name": "Annual salary" },
            { "locale": "de-CH", "name": "Jahresgehalt" },
            { "locale": "fr-CH", "name": "Salaire annuel" },
            { "locale": "it-CH", "name": "Stipendio annuo" },
            { "locale": "rm-CH", "name": "Paja annuala" }
